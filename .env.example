# --- Mode ---
TITAN_MODE=paper                 # paper | live   (live requires explicit override; see risk/limits.py)
TITAN_ENV=dev
TITAN_SIM_MODE=0                 # 0 = real clock + market-hours gate; 1 = explicit labeled simulation

# --- Capital / risk caps (₹) ---
TITAN_CAPITAL=500000
TITAN_MAX_RISK_PER_TRADE_PCT=1.0
TITAN_MAX_DAILY_LOSS_PCT=2.0
TITAN_MAX_DAILY_PROFIT_PCT=4.0       # profit-lock: halt new entries once gains hit this (0 = off)
TITAN_MAX_WEEKLY_LOSS_PCT=5.0
TITAN_MAX_DRAWDOWN_PCT=10.0
TITAN_MAX_CONSECUTIVE_LOSSES=5
TITAN_MAX_CONCURRENT_POSITIONS=3
TITAN_INTRADAY_SQUARE_OFF=15:15  # IST

# --- Postgres ---
TITAN_DB_URL=postgresql+psycopg://titan:titan@localhost:5432/titan

# --- Redis ---
TITAN_REDIS_URL=redis://localhost:6379/0

# NOTE: If you run api/dashboard INSIDE docker compose, change `localhost` to
# `postgres` and `redis` (docker network hostnames). Running on the host (your
# Mac), keep `localhost` — the compose file maps both ports to 127.0.0.1.

# --- Angel One SmartAPI ---
# Get from https://smartapi.angelone.in/
ANGELONE_API_KEY=
ANGELONE_CLIENT_CODE=
ANGELONE_PASSWORD=             # MPIN
ANGELONE_TOTP_SECRET=          # base32 secret from 2FA QR; used with pyotp

# --- Alerts ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Trading universe (comma-separated tradingsymbols) ---
TITAN_UNIVERSE=NIFTY,BANKNIFTY,FINNIFTY,RELIANCE,HDFCBANK,ICICIBANK
TITAN_INSTRUMENT_KIND=ETF        # ETF (default, ₹5K-tradable) | OPTION | INDEX (paper-only) | EQUITY
                                 # underlying→instrument map in config/instrument_map.yaml

# --- Auto-pilot (decision-driven strategy selection; see docs/08) ---
TITAN_AUTOPILOT_ENABLED=0          # 0 = observe-only (classify + log, no arming); 1 = arm
TITAN_AUTOPILOT_VALIDATED=orb      # ONLY these (walk-forward-passed) strategies are auto-armable
TITAN_AUTOPILOT_INTERVAL_S=30      # regime re-evaluation cadence (seconds)
TITAN_AUTOPILOT_REF_SYMBOL=NIFTY   # symbol whose 5m bars define the market regime

# --- Regime classifier thresholds (deterministic; no ML) ---
TITAN_REGIME_ADX_TREND=22.0         # ADX >= → TREND
TITAN_REGIME_ADX_RANGE=18.0         # ADX <  → RANGE
TITAN_REGIME_VOL_CRISIS_PCTILE=0.90 # realized-vol percentile → CRISIS (arm nothing)
TITAN_REGIME_VIX_CRISIS=25.0        # India VIX → CRISIS (only used if titan:vix is set)
TITAN_REGIME_LOOKBACK_BARS=200      # window for ADX / vol percentile

# --- Manifesto Scenario A: feed resilience & data integrity ---
TITAN_FEED_REST_BRIDGE_AFTER_S=5    # soft-stale → bridge prices via REST LTP while WS recovers
TITAN_FEED_STALE_AFTER_S=30         # hard-stale → restart the feed process
TITAN_FEED_REST_FALLBACK=true       # master switch for the REST bridge
TITAN_TICK_FILTER_ENABLED=true      # reject corrupted quotes before aggregation
TITAN_TICK_OUTLIER_SIGMA=4.0        # drop ticks > Nσ from trailing VWAP → ticks:deadletter:<sym>
TITAN_TICK_FILTER_WINDOW_S=300
TITAN_TICK_FILTER_MIN_SAMPLES=20
TITAN_ORDER_LOCK_TTL_S=30           # dispatch dedup lock; held on ambiguous timeouts for reconciliation

# --- Manifesto Scenario B: 2026 compliance (verify rules against official sources) ---
TITAN_MAX_OPS=10.0                  # client-side orders-per-second cap (token bucket)
TITAN_OPS_BURST=10
TITAN_STRATEGY_IDS=                 # exchange Strategy IDs, e.g. "orb:NSE123,vwap_revert:NSE456"
TITAN_STRATEGY_ID_DEFAULT=          # fallback Strategy ID (else ALGO_ID env)

# --- Manifesto §3: self-healing walk-forward daemon ---
TITAN_WF_DAEMON_WEEKDAY=5           # Mon=0…Sun=6 (default Sat)
TITAN_WF_DAEMON_HOUR=18             # IST
TITAN_WF_DAEMON_TF=5m
TITAN_WF_DAEMON_MAX_BARS=0          # 0 = all history

# --- Manifesto Multiplier 1/3: options pivot + margin (lot sizes are exchange-set; verify!) ---
TITAN_LOT_SIZES=NIFTY:65,BANKNIFTY:30,FINNIFTY:60,MIDCPNIFTY:120,SENSEX:20
TITAN_OPTION_STRIKE_STEPS=NIFTY:50,BANKNIFTY:100,FINNIFTY:50,SENSEX:100
TITAN_OPTION_EXPIRY_WEEKDAY=3       # Mon=0…Sun=6 (verify per index; reforms have shifted these)
TITAN_OPTION_OFFSET_STEPS=0         # 0 = ATM; +n = n strikes OTM
TITAN_ORDER_EXEC_MODE=MARKET        # MARKET | MIDPOINT_LIMIT (peg limit to midpoint, kill slippage)
TITAN_LIMIT_FILL_TIMEOUT_S=15
TITAN_MARGIN_CHECK_ENABLED=false    # pre-trade SPAN+Exposure check + OTM downsize/pivot (needs live API)
TITAN_MARGIN_BUFFER_PCT=5.0
TITAN_MARGIN_MAX_OTM_STEPS=5

# --- Manifesto Multiplier 2: predictive FinBERT regime override ---
TITAN_REGIME_NEWS_OVERRIDE=true     # force CRISIS preemptively on strong negative sentiment
TITAN_REGIME_NEWS_CRISIS_P=0.85     # FinBERT negative probability threshold (fed via titan:news:neg_p)

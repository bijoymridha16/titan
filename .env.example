# --- Mode ---
TITAN_MODE=paper                 # paper | live   (live requires explicit override; see risk/limits.py)
TITAN_ENV=dev

# --- Capital / risk caps (₹) ---
TITAN_CAPITAL=500000
TITAN_MAX_RISK_PER_TRADE_PCT=1.0
TITAN_MAX_DAILY_LOSS_PCT=2.0
TITAN_MAX_WEEKLY_LOSS_PCT=5.0
TITAN_MAX_DRAWDOWN_PCT=10.0
TITAN_MAX_CONSECUTIVE_LOSSES=5
TITAN_MAX_CONCURRENT_POSITIONS=3
TITAN_INTRADAY_SQUARE_OFF=15:15  # IST

# --- Postgres ---
TITAN_DB_URL=postgresql+psycopg://titan:titan@localhost:5432/titan

# --- Redis ---
TITAN_REDIS_URL=redis://localhost:6379/0

# NOTE: If you run api/dashboard INSIDE docker compose, change `localhost` to
# `postgres` and `redis` (docker network hostnames). Running on the host (your
# Mac), keep `localhost` — the compose file maps both ports to 127.0.0.1.

# --- Angel One SmartAPI ---
# Get from https://smartapi.angelone.in/
ANGELONE_API_KEY=
ANGELONE_CLIENT_CODE=
ANGELONE_PASSWORD=             # MPIN
ANGELONE_TOTP_SECRET=          # base32 secret from 2FA QR; used with pyotp

# --- Alerts ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Trading universe (comma-separated tradingsymbols) ---
TITAN_UNIVERSE=NIFTY,BANKNIFTY,FINNIFTY,RELIANCE,HDFCBANK,ICICIBANK
